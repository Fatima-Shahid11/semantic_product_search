    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "\n",
        "def similarity(a, b):\n",
        "    return np.dot(a, b) / (np.linalg.norm(a) * np.linalg.norm(b))\n",
        "\n",
        "e1 = model.encode(\"a black aluminium tray\")\n",
        "e2 = model.encode(\"a dark metal serving plate\")\n",
        "e3 = model.encode(\"a chocolate cake\")\n",
        "\n",
        "print(f\"Tray vs Metal plate: {similarity(e1, e2):.3f}\")\n",
        "print(f\"Tray vs Cake:        {similarity(e1, e3):.3f}\")"
      ],
      "metadata": {
