        "from PIL import Image\n",
        "from tqdm.auto import tqdm\n",
        "\n",
        "BATCH_SIZE = 32\n",
        "all_ids, all_embeddings, all_metadatas = [], [], []\n",
        "\n",
        "# Loop through the sample in batches\n",
        "for i in tqdm(range(0, len(df_sample), BATCH_SIZE)):\n",
        "    batch = df_sample.iloc[i:i + BATCH_SIZE]\n",
        "\n",
        "    # Load each image in the batch\n",
        "    images, ids, metas = [], [], []\n",
        "    for _, row in batch.iterrows():\n",
        "        try:\n",
        "            img = Image.open(f\"fashion_data/images/{row['id']}.jpg\").convert(\"RGB\")\n",
        "            images.append(img)\n",
        "            ids.append(str(row['id']))\n",
        "            metas.append({\n",
        "                \"name\": str(row['productDisplayName']),\n",
        "                \"category\": str(row['masterCategory']),\n",
        "                \"subcategory\": str(row['subCategory']),\n",
        "                \"color\": str(row['baseColour']),\n",
        "            })\n",
        "        except Exception:\n",
        "            continue\n",
        "\n",
        "    # Embed all images in this batch at once\n",
        "    if images:\n",
        "        embeddings = model.encode(images, show_progress_bar=False)\n",
        "        all_ids.extend(ids)\n",
        "        all_embeddings.extend(embeddings.tolist())\n",
        "        all_metadatas.extend(metas)\n",
