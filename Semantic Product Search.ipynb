        "def text_search(query, k):\n",
        "    if not query.strip():\n",
        "        return []\n",
        "    q_emb = model.encode(query).tolist()\n",
        "    results = collection.query(query_embeddings=[q_emb], n_results=int(k))\n",
        "    return format_results(results)\n",
        "\n",
        "\n",
        "def image_search(image, k):\n",
        "    if image is None:\n",
        "        return []\n",
        "    q_emb = model.encode(image).tolist()\n",
        "    results = collection.query(query_embeddings=[q_emb], n_results=int(k))\n",
        "    return format_results(results)\n",
        "\n",
        "\n",
        "def pdf_search(pdf_file, k):\n",
        "    if pdf_file is None:\n",
        "        return [], \"No PDF uploaded\"\n",
        "\n",
        "    pdf_images = extract_images_from_pdf(pdf_file.name)\n",
        "    if not pdf_images:\n",
        "        return [], \"No images found in PDF\"\n",
        "\n",
        "    pdf_embeddings = model.encode(pdf_images).tolist()\n",
        "    results = collection.query(query_embeddings=pdf_embeddings, n_results=int(k))\n",
        "\n",
        "    # Combine matches from every PDF image into one gallery\n",
        "    combined = []\n",
        "    for idx in range(len(pdf_images)):\n",
        "        combined.extend(format_results(results, query_idx=idx))\n",
        "\n",
        "    status = f\"Found {len(pdf_images)} images in PDF → {len(combined)} matches\"\n",
        "    return combined, status"
      ],
