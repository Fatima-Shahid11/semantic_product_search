      "source": [
        "import fitz  # this is what PyMuPDF is called when you import it\n",
        "import io\n",
        "\n",
        "def extract_images_from_pdf(pdf_path):\n",
        "    \"\"\"Return list of PIL images found in the PDF.\"\"\"\n",
        "    doc = fitz.open(pdf_path)\n",
        "    images = []\n",
        "\n",
        "    for page_num in range(len(doc)):\n",
        "        page = doc[page_num]\n",
        "        for img_info in page.get_images(full=True):\n",
        "            xref = img_info[0]\n",
        "            base_image = doc.extract_image(xref)\n",
        "            image_bytes = base_image[\"image\"]\n",
        "            img = Image.open(io.BytesIO(image_bytes)).convert(\"RGB\")\n",
        "            images.append(img)\n",
        "\n",
        "    doc.close()\n",
        "    return images"
      ],
      "metadata": {
        "id": "1hTWi6nwq3Kd"
      },
      "execution_count": 30,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def search_by_pdf(pdf_path, k=5):\n",
        "    \"\"\"Extract images from PDF, use each as a query, combine top results.\"\"\"\n",
        "    pdf_images = extract_images_from_pdf(pdf_path)\n",
        "    print(f\"Found {len(pdf_images)} images in PDF\")\n",
        "\n",
        "    if not pdf_images:\n",
        "        return None\n",
        "\n",
        "    # Embed all extracted images at once\n",
        "    pdf_embeddings = model.encode(pdf_images).tolist()\n",
        "\n",
        "    # Query ChromaDB with all embeddings; each returns k matches\n",
        "    results = collection.query(query_embeddings=pdf_embeddings, n_results=k)\n",
        "\n",
        "    return pdf_images, results"
      ],
      "metadata": {
        "id": "PQ5Hm5q7s_5n"
      },
