        "import gradio as gr\n",
        "\n",
        "with gr.Blocks(title=\"Semantic Product Search\") as demo:\n",
        "    gr.Markdown(\"# 🔍 Semantic Product Image Search\")\n",
        "    gr.Markdown(\"Search 5000 products by text, image, or PDF mood board. Powered by CLIP + ChromaDB.\")\n",
        "\n",
        "    with gr.Tabs():\n",
        "\n",
        "        # -------- Tab 1: Text search --------\n",
        "        with gr.Tab(\"Text Search\"):\n",
        "            with gr.Row():\n",
        "                text_input = gr.Textbox(\n",
        "                    label=\"Describe what you're looking for\",\n",
        "                    placeholder=\"e.g., black shoes, red handbag, blue summer dress\"\n",
        "                )\n",
        "                text_k = gr.Slider(1, 20, value=8, step=1, label=\"Number of results\")\n",
        "            text_btn = gr.Button(\"Search\", variant=\"primary\")\n",
        "            text_gallery = gr.Gallery(label=\"Results\", columns=4, height=500)\n",
        "            text_btn.click(text_search, inputs=[text_input, text_k], outputs=text_gallery)\n",
        "\n",
        "        # -------- Tab 2: Image search --------\n",
        "        with gr.Tab(\"Image Search\"):\n",
        "            with gr.Row():\n",
        "                image_input = gr.Image(type=\"pil\", label=\"Upload an image\")\n",
        "                image_k = gr.Slider(1, 20, value=8, step=1, label=\"Number of results\")\n",
        "            image_btn = gr.Button(\"Find similar\", variant=\"primary\")\n",
        "            image_gallery = gr.Gallery(label=\"Similar products\", columns=4, height=500)\n",
        "            image_btn.click(image_search, inputs=[image_input, image_k], outputs=image_gallery)\n",
        "\n",
        "        # -------- Tab 3: PDF mood board --------\n",
        "        with gr.Tab(\"PDF Mood Board\"):\n",
        "            with gr.Row():\n",
        "                with gr.Column():\n",
        "                    pdf_input = gr.File(label=\"Upload a mood board PDF\", file_types=[\".pdf\"])\n",
        "                    pdf_preview = gr.Image(\n",
        "                        label=\"PDF Preview\",\n",
        "                        interactive=False,\n",
        "                        height=300,\n",
        "                    )\n",
        "                pdf_k = gr.Slider(1, 10, value=3, step=1, label=\"Matches per image\")\n",
        "\n",
        "            pdf_btn = gr.Button(\"Find inspiration matches\", variant=\"primary\")\n",
        "            pdf_gallery = gr.Gallery(label=\"Matched products\", columns=4, height=500)\n",
        "\n",
        "            def show_pdf_preview(pdf_file):\n",
        "                if pdf_file is None:\n",
        "                    return None\n",
        "                doc = fitz.open(pdf_file.name)\n",
        "                pix = doc[0].get_pixmap(dpi=120)\n",
        "                doc.close()\n",
        "                from PIL import Image as PILImage\n",
        "                import io\n",
        "                img = PILImage.open(io.BytesIO(pix.tobytes(\"png\")))\n",
        "                return img\n",
        "\n",
        "            def pdf_search_no_status(pdf_file, k):\n",
        "                result = pdf_search(pdf_file, k)\n",
        "                return result[0]   # only the gallery, drop the status\n",
        "\n",
        "            pdf_input.change(show_pdf_preview, inputs=pdf_input, outputs=pdf_preview)\n",
        "            pdf_btn.click(pdf_search_no_status, inputs=[pdf_input, pdf_k], outputs=pdf_gallery)\n",
        "\n",
        "    gr.Markdown(\"---\")\n",
        "    gr.Markdown(\"*Demo indexed on 5,000 fashion products. Production system scales to 50K+ with sub-second search.*\")\n",
        "\n",
        "demo.launch(share=True, debug=True)"
