        "def format_results(results, query_idx=0):\n",
        "    \"\"\"Turn ChromaDB results into a list Gradio Gallery can display.\"\"\"\n",
        "    gallery_items = []\n",
        "    for i in range(len(results['ids'][query_idx])):\n",
        "        img_id = results['ids'][query_idx][i]\n",
        "        meta = results['metadatas'][query_idx][i]\n",
        "        distance = results['distances'][query_idx][i]\n",
        "        img_path = f\"fashion_data/images/{img_id}.jpg\"\n",
        "        caption = f\"{meta['name'][:30]}\\n{meta['color']} | dist: {distance:.3f}\"\n",
        "        gallery_items.append((img_path, caption))\n",
        "    return gallery_items"
      ],
      "metadata": {
        "id": "ayvZvEtPvzKK"
      },
      "execution_count": 38,
      "outputs": []
