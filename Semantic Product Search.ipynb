      "cell_type": "code",
      "source": [
        "# Import the SentenceTransformer class from the library we installed.\n",
        "# SentenceTransformer is a wrapper that makes CLIP easy to use.\n",
        "from sentence_transformers import SentenceTransformer\n",
        "\n",
        "# Download and load a pretrained CLIP model.\n",
        "# clip ViT B 32 is CLIP's base version. About 150 MB, fast, and works well.\n",
        "# First run: downloads the model (about 1 minute).\n",
        "# Later runs: instant, since it's cached.\n",
        "model = SentenceTransformer('clip-ViT-B-32')\n",
        "\n",
        "print(\"CLIP model loaded successfully\")"
      ],
      "metadata": {
